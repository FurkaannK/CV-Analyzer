<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CVAnalyzer Admin</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f6f8;
            margin: 0;
            overflow-x: hidden;
        }

        /* Sidebar Sizing and Coloring */
        .admin-sidebar {
            width: 280px;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: #ffffff;
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
            z-index: 1040;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease;
        }

        .admin-main {
            margin-left: 280px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left 0.3s ease;
        }

        .nav-link.admin-menu-item {
            color: #495057;
            border-radius: 0.5rem;
            margin: 0.2rem 1rem;
            padding: 0.75rem 1.25rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .nav-link.admin-menu-item:hover {
            background-color: #f8f9fa;
            color: #0d6efd;
        }

        .nav-link.admin-menu-item.active {
            background-color: #e7f1ff;
            color: #0d6efd;
            font-weight: 600;
        }

        .nav-link.admin-menu-item i {
            font-size: 1.25rem;
            vertical-align: text-bottom;
            margin-right: 0.75rem;
        }

        /* Mobile Sidebar Toggle */
        @@media (max-width: 991.98px) {
            .admin-sidebar {
                transform: translateX(-100%);
            }
            .admin-sidebar.show {
                transform: translateX(0);
            }
            .admin-main {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="admin-sidebar" id="adminSidebar">
        <!-- Logo Area -->
        <div class="p-4 d-flex justify-content-between align-items-center border-bottom">
            <a href="/Admin/Index" class="text-decoration-none d-flex align-items-center">
                <div class="bg-primary text-white rounded d-flex align-items-center justify-content-center me-2 shadow-sm" style="width: 36px; height: 36px;">
                    <i class="ti ti-briefcase fs-4"></i>
                </div>
                <span class="fs-4 fw-bold text-dark" style="letter-spacing: -0.5px;">ATS<span class="text-primary">Admin</span></span>
            </a>
            <button class="btn btn-sm btn-light d-lg-none" onclick="toggleSidebar()">
                <i class="ti ti-x fs-4"></i>
            </button>
        </div>

        <!-- Navigation Menu -->
        <div class="flex-grow-1 overflow-auto py-3">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link admin-menu-item active" asp-controller="Admin" asp-action="Index">
                        <i class="ti ti-layout-dashboard"></i> Gösterge Paneli
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link admin-menu-item" href="#">
                        <i class="ti ti-users"></i> Tüm Adaylar
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link admin-menu-item" href="#">
                        <i class="ti ti-sparkles text-warning"></i> Akıllı Arama
                        <span class="badge bg-warning text-dark ms-auto" style="font-size: 0.7rem;">YAKINDA</span>
                    </a>
                </li>
            </ul>

            <hr class="mx-3 my-4 text-muted">

            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link admin-menu-item" href="#">
                        <i class="ti ti-settings"></i> Şirket Ayarları
                    </a>
                </li>
            </ul>
        </div>

        <!-- User Area at Bottom -->
        <div class="p-3 border-top mt-auto">
            <div class="d-flex align-items-center p-2 rounded hover-bg-light cursor-pointer dropdown" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; min-width: 40px;">
                    <span class="fw-bold">@User.Identity?.Name?.Substring(0, 1).ToUpper()</span>
                </div>
                <div class="ms-3 overflow-hidden text-nowrap" style="text-overflow: ellipsis;">
                    <h6 class="mb-0 fw-semibold text-dark">@User.Identity?.Name</h6>
                    <small class="text-muted">İşveren</small>
                </div>
                <i class="ti ti-chevron-up ms-auto text-muted"></i>
            </div>
            
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 w-100">
                <li>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="ti ti-logout me-2"></i> Çıkış Yap
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="admin-main">
        <!-- Topbar for Mobile Toggle -->
        <header class="d-lg-none bg-white p-3 shadow-sm border-bottom d-flex align-items-center">
            <button class="btn btn-light me-3" onclick="toggleSidebar()">
                <i class="ti ti-menu-2 fs-4"></i>
            </button>
            <span class="fs-5 fw-bold text-dark">ATS<span class="text-primary">Admin</span></span>
        </header>

        <!-- Dynamic Page Content -->
        <div class="flex-grow-1 p-3 p-md-4 p-lg-5">
            @RenderBody()
        </div>
    </main>

    <!-- Overlay for mobile sidebar -->
    <div class="modal-backdrop fade show d-none" id="sidebarOverlay" style="z-index: 1030;" onclick="toggleSidebar()"></div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            var sidebar = document.getElementById('adminSidebar');
            var overlay = document.getElementById('sidebarOverlay');
            if (sidebar.classList.contains('show')) {
                sidebar.classList.remove('show');
                overlay.classList.add('d-none');
            } else {
                sidebar.classList.add('show');
                overlay.classList.remove('d-none');
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
