<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")CVScore</title>
    <meta name="description" content="Yapay zeka destekli CV analiz aracı. CV'nizi analiz edin, eksiklerinizi keşfedin." />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@3.3.0/tabler-icons.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (ViewData["HideNavbar"] as bool? != true)
{
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark glass-nav sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <div class="brand-icon"><i class="ti ti-file-cv"></i></div>
                <span>CV<span class="text-accent">Score</span></span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="ti ti-home me-1"></i>Ana Sayfa
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CV" asp-action="Analyze">
                            <i class="ti ti-scan me-1"></i>CV Analiz
                        </a>
                    </li>

                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link text-primary fw-medium" asp-controller="Profile" asp-action="Index">
                                <i class="ti ti-user-circle me-1"></i>@User.Identity.Name
                            </a>
                        </li>
                        <li class="nav-item ms-lg-1">
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm mt-1">
                                    <i class="ti ti-logout me-1"></i>Çıkış
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-outline-primary btn-sm mt-1" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm mt-1" asp-controller="Auth" asp-action="Register" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); border: none;">Kayıt Ol</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
}

<!-- Main content -->
<main>
    @RenderBody()
</main>

<!-- Footer -->
<footer class="footer mt-5 py-4 border-top">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 text-muted small">
                © @DateTime.Now.Year CVScore — Yapay zeka destekli CV analiz platformu
            </div>
            <div class="col-md-6 text-md-end small">
                <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Gizlilik</a>
            </div>
        </div>
    </div>
</footer>

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<!-- Custom JS -->
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
