@model List<CVAnalyzer.Models.SmartSearchResultViewModel>

@if (!Model.Any())
{
    <div class="alert alert-warning border-0 bg-warning-subtle text-warning">
        <i class="ti ti-alert-circle me-2"></i> Kriterlerinize uygun aday bulunamadı. Lütfen farklı kelimelerle tekrar deneyin.
    </div>
}
else
{
    <div class="row">
        @foreach (var result in Model)
        {
            var cv = result.Candidate;
            var pd = cv.ParsedData;
            
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow-sm hover-elevate">
                    <div class="card-body position-relative">
                        <!-- Score Badge -->
                        <div class="position-absolute top-0 end-0 mt-3 me-3">
                            <span class="badge @(result.MatchScore >= 80 ? "bg-success" : result.MatchScore >= 60 ? "bg-warning" : "bg-secondary") rounded-pill px-3 py-2 fs-6">
                                %@result.MatchScore Uyumlu
                            </span>
                        </div>

                        <!-- Profile Info -->
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                <i class="ti ti-user fs-4"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold">@(pd.Personal?.FullName ?? cv.User?.FullName ?? "İsimsiz Aday")</h5>
                                <span class="text-muted small">@pd.Headline</span>
                            </div>
                        </div>

                        <!-- AI Reason -->
                        <div class="p-3 bg-light rounded mb-3 border-start border-4 @(result.MatchScore >= 80 ? "border-success" : "border-primary")">
                            <p class="mb-0 small fw-medium text-dark">
                                <i class="ti ti-check text-success me-1"></i> @result.Reason
                            </p>
                            @if (result.IsLocationMatched)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle mt-2"><i class="ti ti-map-pin"></i> Lokasyon Uyumu</span>
                            }
                            @if (result.IsExperienceMatched)
                            {
                                <span class="badge bg-info-subtle text-info border border-info-subtle mt-2"><i class="ti ti-briefcase"></i> Deneyim Uyumu</span>
                            }
                        </div>

                        <!-- Skills -->
                        <div class="mb-3">
                            @foreach (var skill in pd.Skills.Take(8))
                            {
                                bool isMatched = result.MatchedSkills.Any(s => s.Equals(skill.Name, StringComparison.OrdinalIgnoreCase));
                                <span class="badge @(isMatched ? "bg-success text-white" : "bg-light text-dark") border me-1 mb-1">
                                    @(isMatched ? "✓ " : "")@skill.Name
                                </span>
                            }
                            @if (pd.Skills.Count > 8)
                            {
                                <span class="badge bg-light text-muted border mb-1">+@(pd.Skills.Count - 8)</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 pt-0">
                        <a href="@Url.Action("CandidateProfile", "Admin", new { id = cv.UserId })" class="btn btn-outline-primary w-100 rounded-3">
                            Profili İncele
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
